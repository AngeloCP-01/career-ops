# Personal data (user fills these)
cv.md
data/applications.md
data/pipeline.md
data/scan-history.tsv
reports/*.md
!reports/.gitkeep
output/*
!output/.gitkeep
batch/logs/*
!batch/logs/.gitkeep
batch/batch-state.tsv
batch/batch-input.tsv
batch/tracker-additions/**/*.tsv
!batch/tracker-additions/.gitkeep
jds/*
!jds/.gitkeep

# Writing samples (user's personal files — never committed)
writing-samples/*
!writing-samples/README.md

# User config and customization (never auto-updated)
config/profile.yml
portals.yml
modes/_profile.md
.update-dismissed
.update-lock

# Secrets (never commit — use .env.example as template)
.env

# Generated
.resolved-prompt-*
node_modules/
bun.lock

# OS
.DS_Store
*.mov
*.mp4

# Claude Code local
.claude/settings.local.json
.claude/memory/
.claude/projects/
career-dashboard
package-lock.json

# Playwright MCP cache and session data
.playwright-mcp/

# Backup files
*.bak

# Personal CV uploads / extracted source documents (user-specific, never push)
config/*.pdf
config/*.docx
config/*.docx.md
config/*.doc

# Session handoff notes (personal context, local-only)
NOTES.md